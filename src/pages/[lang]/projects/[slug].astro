---
import { render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { useTranslations } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/ui";
import {
  getProjectsByLang,
  projectSlug,
  type Project,
} from "../../../utils/projects";

export async function getStaticPaths() {
  const langs: Lang[] = ["es", "en"];
  const paths = [];
  for (const lang of langs) {
    const projects = await getProjectsByLang(lang);
    for (const project of projects) {
      paths.push({
        params: { lang, slug: projectSlug(project) },
        props: { project },
      });
    }
  }
  return paths;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const { Content } = await render(project);
const { title, description, stack, repoUrl, liveUrl, cover } = project.data;
---

<BaseLayout title={title} description={description} image={cover || "/og-image.png"}>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <a
      href={`/${lang}/projects`}
      class="inline-flex items-center gap-1 text-sm font-medium text-brand-600 hover:text-brand-700 dark:text-brand-400"
    >
      &larr; {t("projects.back")}
    </a>

    <h1 class="mt-6 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
      {title}
    </h1>
    <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">{description}</p>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      {
        repoUrl && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
          >
            {t("projects.viewRepo")}
          </a>
        )
      }
      {
        liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-700"
          >
            {t("projects.viewLive")}
          </a>
        )
      }
    </div>

    {
      cover && (
        <img
          src={cover}
          alt={title}
          class="mt-8 w-full rounded-xl border border-slate-200 dark:border-slate-800"
        />
      )
    }

    <div class="mt-8">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
        {t("projects.stack")}
      </h2>
      <ul class="mt-3 flex flex-wrap gap-2">
        {
          stack.map((tech) => (
            <li class="rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200">
              {tech}
            </li>
          ))
        }
      </ul>
    </div>

    <div
      class="prose prose-slate mt-10 max-w-none dark:prose-invert prose-headings:font-semibold prose-a:text-brand-600"
    >
      <Content />
    </div>
  </article>
</BaseLayout>
