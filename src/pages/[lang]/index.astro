---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import {
  profile,
  bio,
  experience,
  education,
  skills,
} from "../../data/site";
import { getProjectsByLang, projectUrl } from "../../utils/projects";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const projects = await getProjectsByLang(lang);
const featured = projects.filter((p) => p.data.featured);
const cvHref = profile.cv[lang];
---

<BaseLayout title={t("nav.home")} description={bio[lang]}>
  <!-- Hero -->
  <section
    class="mx-auto max-w-5xl px-4 pb-16 pt-16 sm:px-6 sm:pt-24"
  >
    <p class="text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">
      {t("hero.role")}
    </p>
    <h1
      class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-6xl dark:text-white"
    >
      {profile.name}
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
      {t("hero.tagline")}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={`/${lang}/projects`}
        class="rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700"
      >
        {t("hero.cta.projects")}
      </a>
      <a
        href={cvHref}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        {t("hero.cta.cv")}
      </a>
      <a
        href="#contact"
        class="rounded-lg px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        {t("hero.cta.contact")}
      </a>
    </div>
  </section>

  <!-- About / CV -->
  <section
    id="about"
    class="scroll-mt-24 border-t border-slate-200/70 bg-slate-50/50 dark:border-slate-800/70 dark:bg-slate-900/30"
  >
    <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl dark:text-white">
        {t("about.title")}
      </h2>
      <p class="mt-4 max-w-3xl text-slate-600 dark:text-slate-300">
        {bio[lang]}
      </p>

      <div class="mt-10 grid gap-10 md:grid-cols-2">
        <!-- Experience -->
        <div>
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white">
            {t("about.experience")}
          </h3>
          <ul class="mt-4 space-y-5">
            {
              experience.map((item) => (
                <li class="border-l-2 border-brand-500 pl-4">
                  <p class="font-medium text-slate-900 dark:text-white">
                    {item.role[lang]}
                  </p>
                  <p class="text-sm text-slate-500 dark:text-slate-400">
                    {item.company} · {item.period[lang]}
                  </p>
                  <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                    {item.description[lang]}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Education -->
        <div>
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white">
            {t("about.education")}
          </h3>
          <ul class="mt-4 space-y-5">
            {
              education.map((item) => (
                <li class="border-l-2 border-slate-300 pl-4 dark:border-slate-600">
                  <p class="font-medium text-slate-900 dark:text-white">
                    {item.title[lang]}
                  </p>
                  <p class="text-sm text-slate-500 dark:text-slate-400">
                    {item.institution} · {item.period[lang]}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Skills -->
      <div class="mt-10">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">
          {t("about.skills")}
        </h3>
        <ul class="mt-4 flex flex-wrap gap-2">
          {
            skills.map((skill) => (
              <li class="rounded-full border border-slate-200 bg-white px-3 py-1 text-sm text-slate-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200">
                {skill}
              </li>
            ))
          }
        </ul>
      </div>

      <a
        href={cvHref}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400"
      >
        {t("about.downloadCv")} &darr;
      </a>
    </div>
  </section>

  <!-- Featured projects -->
  {
    featured.length > 0 && (
      <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
        <div class="flex items-end justify-between">
          <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl dark:text-white">
            {t("projects.featured")}
          </h2>
          <a
            href={`/${lang}/projects`}
            class="text-sm font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400"
          >
            {t("projects.all")} &rarr;
          </a>
        </div>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map((project) => (
            <ProjectCard
              href={projectUrl(lang, project)}
              title={project.data.title}
              description={project.data.description}
              stack={project.data.stack}
              cover={project.data.cover}
            />
          ))}
        </div>
      </section>
    )
  }

  <!-- Contact -->
  <section
    id="contact"
    class="scroll-mt-24 border-t border-slate-200/70 dark:border-slate-800/70"
  >
    <div class="mx-auto max-w-5xl px-4 py-16 text-center sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl dark:text-white">
        {t("contact.title")}
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-slate-600 dark:text-slate-300">
        {t("contact.subtitle")}
      </p>
      <a
        href={`mailto:${profile.email}`}
        class="mt-8 inline-block rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700"
      >
        {t("contact.email")}
      </a>
    </div>
  </section>
</BaseLayout>
