---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { profile } from "../data/site";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer
  class="border-t border-slate-200/70 dark:border-slate-800/70"
>
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-3 px-4 py-8 text-sm text-slate-500 sm:flex-row sm:px-6 dark:text-slate-400"
  >
    <p>&copy; {year} {profile.name}</p>
    <div class="flex items-center gap-4">
      <a
        href={profile.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="transition hover:text-slate-900 dark:hover:text-white"
      >
        GitHub
      </a>
      <a
        href={profile.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="transition hover:text-slate-900 dark:hover:text-white"
      >
        LinkedIn
      </a>
      <a
        href={`mailto:${profile.email}`}
        class="transition hover:text-slate-900 dark:hover:text-white"
      >
        Email
      </a>
    </div>
    <p class="text-xs">{t("footer.builtWith")}</p>
  </div>
</footer>
