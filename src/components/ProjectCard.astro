---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  href: string;
  title: string;
  description: string;
  stack: string[];
  cover?: string;
}

const { href, title, description, stack, cover } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<article
  class="group flex h-full flex-col overflow-hidden rounded-xl border border-slate-200 bg-white transition hover:border-brand-300 hover:shadow-lg dark:border-slate-800 dark:bg-slate-900 dark:hover:border-brand-700"
>
  {
    cover ? (
      <a href={href} class="block aspect-video overflow-hidden bg-slate-100 dark:bg-slate-800">
        <img
          src={cover}
          alt={title}
          loading="lazy"
          class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
        />
      </a>
    ) : (
      <a
        href={href}
        class="flex aspect-video items-center justify-center bg-gradient-to-br from-brand-100 to-brand-200 text-2xl font-bold text-brand-700 dark:from-slate-800 dark:to-slate-700 dark:text-brand-300"
      >
        {title.charAt(0)}
      </a>
    )
  }

  <div class="flex flex-1 flex-col p-5">
    <h3 class="text-lg font-semibold text-slate-900 dark:text-white">
      <a href={href} class="after:absolute hover:text-brand-600 dark:hover:text-brand-400">
        {title}
      </a>
    </h3>
    <p class="mt-2 flex-1 text-sm text-slate-600 dark:text-slate-400">
      {description}
    </p>
    <ul class="mt-4 flex flex-wrap gap-1.5">
      {
        stack.slice(0, 4).map((tech) => (
          <li class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
            {tech}
          </li>
        ))
      }
    </ul>
    <span class="mt-4 text-sm font-medium text-brand-600 dark:text-brand-400">
      {t("projects.viewLive")} &rarr;
    </span>
  </div>
</article>
